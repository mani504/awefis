<!DOCTYPE html>
<html>

<head>

<meta charset="utf-8">

<title>SDNO Whitebox Demo</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#fff;
color:#222;
}

.hidden{
display:none!important;
}

.header{
height:58px;
border-bottom:1px solid #eee;
display:flex;
align-items:center;
padding:0 28px;
}

.logo{
font-weight:700;
margin-right:70px;
}

.nav{
display:flex;
gap:48px;
font-size:13px;
}

.nav-item{
cursor:pointer;
position:relative;
}

.dropdown{
position:absolute;
top:30px;
left:-10px;
width:180px;
background:white;
border:1px solid #ddd;
display:none;
z-index:99;
}

.dropdown div{
padding:12px;
cursor:pointer;
}

.dropdown div:hover{
background:#f4f4f4;
}

.page{
padding:18px 32px;
}

.tabs{
display:flex;
gap:26px;
margin-bottom:18px;
}

.tab{
cursor:pointer;
padding-bottom:8px;
}

.active{
border-bottom:2px solid black;
font-weight:600;
}

.filters{
display:flex;
gap:10px;
margin-bottom:20px;
}

.filter{
background:#333;
color:white;
padding:8px 12px;
font-size:12px;
}

.filter:first-child{
background:#0a66cc;
}

.toolbar{
display:flex;
justify-content:flex-end;
gap:10px;
margin-bottom:14px;
}

.btn{
height:34px;
padding:0 16px;
background:#111;
color:white;
border:none;
cursor:pointer;
}

table{
width:100%;
border-collapse:collapse;
}

th{
padding:12px;
background:#fafafa;
text-align:left;
}

td{
padding:14px;
border-bottom:1px solid #eee;
}

.switch{
width:30px;
height:14px;
border-radius:10px;
background:#888;
}

.green{
color:#0b8d4e;
}

.red{
color:#d74c4c;
}

.modal{
position:fixed;
inset:0;
display:none;
justify-content:center;
align-items:center;
background:rgba(0,0,0,.3);
}

.box{
background:white;
width:580px;
padding:30px;
}

label{
display:block;
margin-top:14px;
margin-bottom:8px;
}

select,input{
width:100%;
height:42px;
padding:10px;
}

.actions{
display:flex;
justify-content:flex-end;
gap:10px;
margin-top:20px;
}

.toast{
position:fixed;
right:20px;
top:20px;
background:black;
color:white;
padding:12px 20px;
display:none;
}

.tag{
display:inline-block;
padding:6px 10px;
margin:4px;
border-radius:4px;
font-size:12px;
color:white;
}

.blue{
background:#1976d2;
}

.purple{
background:#7b61ff;
}

</style>

</head>

<body>

<div class="header">

<div class="logo">
SAMSUNG CognitiV/ SDNO
</div>

<div class="nav">

<div>Monitor</div>

<div class="nav-item">

<div onclick="toggleMenu()">
Inventory
</div>

<div id="menu" class="dropdown">

<div>
Device Inventory
</div>

<div onclick="openWhitebox()">
Whitebox Inventory
</div>

</div>

</div>


<div class="nav-item">

<div onclick="toggleConfigMenu()">
Configuration
</div>

<div id="configMenu" class="dropdown">

<div onclick="openNOSProfile()">
NOS Profile
</div>

</div>

</div>

<div>Security</div>

<div>System</div>

</div>

</div>


<div id="home" class="page">

<h2>Device Overview</h2>

<br><br>

No device groups configured

</div>


<div id="whitebox" class="page hidden">

<div class="tabs">

<div class="tab active" id="wbTab" onclick="showWB()">
Whitebox Inventory
</div>

<div class="tab" id="osTab" onclick="showOS()">
OS Profile
</div>

</div>


<div id="wb">

<table>

<tr>

<th></th>
<th>Status</th>
<th>Name</th>
<th>Management IP</th>
<th>Model</th>

</tr>

<tr>

<td>
<input type="checkbox">
</td>

<td class="green">
Provisioned
</td>

<td>
WB_ACCESS_1
</td>

<td>
10.10.10.11
</td>

<td>
WB-48X
</td>

</tr>

</table>

</div>


<div id="os" class="hidden">

<table>

<tr>

<th>Platform</th>
<th>ONIE Version</th>
<th>NOS Version</th>

</tr>

<tr>

<td>WB-48X</td>
<td>ONIE-2025.01</td>
<td>ArcOS-5.4</td>

</tr>

</table>

</div>

</div>


<!-- NEW NOS PROFILE PAGE -->

<div id="nosProfilePage" class="page hidden">

<h2 style="margin-bottom:20px">
NOS Profile
</h2>

<table>

<thead>

<tr>

<th>Model</th>
<th>NOS Version</th>
<th>Firmware</th>

</tr>

</thead>

<tbody id="nosTable">

</tbody>

</table>

</div>


<div id="modal" class="modal">

<div class="box">

<h2>NOS Management</h2>

<label>Device Model</label>

<select>
<option>WB-48X</option>
</select>

<label>NOS Version</label>

<select>
<option>ArcOS-5.4</option>
</select>

<label>NOS Image</label>

<select>
<option>arcos-installer.bin</option>
</select>

<div class="actions">

<button class="btn" onclick="closeModal()">
Cancel
</button>

<button class="btn" onclick="launch()">
Launch
</button>

</div>

</div>

</div>


<div id="toast" class="toast">

Workflow launched

</div>


<script>


const nosDataset=[

{
model:"WB-48X",
nosVersions:[
"ArcOS-5.4",
"ArcOS-5.5"
],
images:[
"arcos-installer.bin",
"upgrade.bin"
]
},

{
model:"WB-32Q",
nosVersions:[
"ArcOS-5.2"
],
images:[
"wb32q.bin"
]
}

]


function toggleMenu(){

menu.style.display=
menu.style.display==="block"
?"none"
:"block"

}


function toggleConfigMenu(){

configMenu.style.display=
configMenu.style.display==="block"
?"none"
:"block"

}


function openWhitebox(){

home.classList.add("hidden")

nosProfilePage.classList.add("hidden")

whitebox.classList.remove("hidden")

}


function openNOSProfile(){

home.classList.add("hidden")

whitebox.classList.add("hidden")

nosProfilePage.classList.remove("hidden")

renderNOS()

}


function renderNOS(){

let html=""

nosDataset.forEach(r=>{

html+=`

<tr>

<td>${r.model}</td>

<td>

${r.nosVersions
.map(v=>
`<span class='tag blue'>${v}</span>`
).join("")}

</td>

<td>

${r.images
.map(v=>
`<span class='tag purple'>${v}</span>`
).join("")}

</td>

</tr>

`

})

nosTable.innerHTML=html

}


function showWB(){

wb.classList.remove("hidden")

os.classList.add("hidden")

}


function showOS(){

wb.classList.add("hidden")

os.classList.remove("hidden")

}


function closeModal(){

modal.style.display="none"

}


function launch(){

toast.style.display="block"

setTimeout(()=>{

toast.style.display="none"

},2500)

}

</script>

</body>

</html>
