<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>SDNO Whitebox Demo</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial;
}

body{
background:#fff;
color:#222;
}

.header{
height:58px;
display:flex;
align-items:center;
padding:0 24px;
border-bottom:1px solid #eee;
}

.logo{
font-weight:700;
margin-right:60px;
}

.nav{
display:flex;
gap:50px;
font-size:13px;
}

.nav span{
cursor:pointer;
}

.content{
padding:16px 28px;
}

.hidden{
display:none;
}

.tabs{
display:flex;
gap:22px;
margin-bottom:16px;
}

.tab{
cursor:pointer;
padding-bottom:8px;
}

.active{
border-bottom:2px solid black;
font-weight:600;
}

.filters{
display:flex;
gap:10px;
margin-bottom:22px;
}

.filter{
background:#333;
color:white;
padding:8px 12px;
font-size:12px;
}

.filter:first-child{
background:#1264cc;
}

.toolbar{
display:flex;
justify-content:flex-end;
margin-bottom:10px;
gap:8px;
}

.btn{
height:34px;
padding:0 16px;
border:none;
background:#111;
color:white;
cursor:pointer;
}

.btn:disabled{
opacity:.35;
}

.refresh{
width:34px;
}

table{
width:100%;
border-collapse:collapse;
}

th{
background:#fafafa;
font-size:12px;
text-align:left;
padding:12px;
}

td{
padding:14px 12px;
border-bottom:1px solid #eee;
font-size:13px;
}

.green{
color:#0b8d4e;
}

.red{
color:#d74c4c;
}

.switch{
width:32px;
height:16px;
background:#999;
border-radius:10px;
}

.modal{
position:fixed;
inset:0;
background:rgba(0,0,0,.35);
display:none;
justify-content:center;
align-items:center;
}

.box{
width:540px;
background:white;
padding:30px;
}

.box h1{
margin-bottom:22px;
}

label{
display:block;
margin-top:18px;
margin-bottom:8px;
}

input,select{
width:100%;
height:44px;
padding:10px;
}

.read{
background:#f6f6f6;
}

.actions{
display:flex;
justify-content:flex-end;
gap:10px;
margin-top:24px;
}

.toast{
position:fixed;
right:20px;
top:20px;
background:#111;
color:white;
padding:14px 20px;
display:none;
}

</style>
</head>

<body>

<div class="header">

<div class="logo">
SAMSUNG CognitiV/ SDNO
</div>

<div class="nav">

<span>Monitor</span>

<span onclick="
document.getElementById('home').classList.add('hidden');
document.getElementById('inventory').classList.remove('hidden')
">
Inventory
</span>

<span>Configuration</span>

<span>Security</span>

<span>System</span>

</div>

</div>

<div id="home" class="content">

<h2>Device Overview</h2>

<br><br>

No device groups configured

</div>

<div id="inventory" class="content hidden">

<div class="tabs">

<div class="tab active">
Whitebox Inventory
</div>

<div class="tab"
onclick="
document.getElementById('wb').classList.add('hidden');
document.getElementById('os').classList.remove('hidden')
">
OS Profile
</div>

</div>

<div id="wb">

<div class="filters">

<div class="filter">ALL(3)</div>

<div class="filter">Provisioned(2)</div>

<div class="filter">Progress Fail(1)</div>

</div>

<div class="toolbar">

<button
id="install"
class="btn"
onclick="openModal()">
NOS Install
</button>

<button class="btn">
Provision
</button>

<button class="btn refresh">
↻
</button>

</div>

<table>

<tr>

<th></th>
<th>Status</th>
<th>Name</th>
<th>Management IP</th>
<th>Model</th>
<th>Provision State</th>
<th>Maintenance Mode</th>

</tr>

<tr>

<td>
<input type="checkbox"
onclick="toggleInstall(this)">
</td>

<td class="green">
Provisioned
</td>

<td>WB_ACCESS_1</td>

<td>10.10.10.11</td>

<td>WB-48X</td>

<td>
<div class="switch"></div>
</td>

<td>
OFF
</td>

</tr>

<tr>

<td>
<input type="checkbox"
onclick="toggleInstall(this)">
</td>

<td class="red">
Progress Fail
</td>

<td>WB_ACCESS_2</td>

<td>10.10.10.12</td>

<td>WB-32Q</td>

<td>
OFF
</td>

<td>
ON
</td>

</tr>

</table>

</div>

<div
id="os"
class="hidden">

<table>

<tr>

<th>Platform</th>
<th>ONIE Version</th>
<th>NOS Version</th>

</tr>

<tr>

<td>WB-48X</td>
<td>ONIE-2025.01</td>
<td>ArcOS-5.4</td>

</tr>

<tr>

<td>WB-32Q</td>
<td>ONIE-2025.02</td>
<td>ArcOS-5.5</td>

</tr>

<tr>

<td>WB-24T</td>
<td>ONIE-2024.11</td>
<td>ArcOS-5.3</td>

</tr>

</table>

</div>

</div>

<div
class="modal"
id="modal">

<div class="box">

<h1>NOS Management</h1>

<label>Device model</label>

<select>

<option>WB-48X</option>

</select>

<label>NOS version</label>

<select>

<option>ArcOS-5.4</option>

</select>

<label>NOS image</label>

<select>

<option>arcos-installer.bin</option>

</select>

<label>Installation Type</label>

<input
class="read"
value="ONIE"
readonly>

<label>Target Device</label>

<select>

<option>SEC_ACCESS1_WBX001</option>

<option>SEC_ACCESS2_WBX002</option>

</select>

<label>Delay before reload</label>

<input
value="00:05">

<div class="actions">

<button
class="btn"
onclick="
closeModal()
">
Cancel
</button>

<button
class="btn"
onclick="
launch()
">
Launch
</button>

</div>

</div>

</div>

<div
class="toast"
id="toast">

Workflow launched successfully

</div>

<script>

function toggleInstall(){

let checked=
document.querySelectorAll(
'input[type=checkbox]:checked'
).length

document
.getElementById('install')
.disabled=
checked>0

}

function openModal(){

if(
document
.getElementById('install')
.disabled
)return

document
.getElementById('modal')
.style.display=
'flex'

}

function closeModal(){

document
.getElementById('modal')
.style.display=
'none'

}

function launch(){

closeModal()

document
.getElementById('toast')
.style.display=
'block'

setTimeout(()=>{
toast.style.display='none'
},2500)

document
.querySelectorAll(
'td.green,td.red'
)[1]
.innerHTML=
'Provisioned'

}

</script>

</body>
</html>
