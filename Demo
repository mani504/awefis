<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">

<title>SDN Orchestrator - MVP</title>

<style>

body{
margin:0;
font-family:Arial;
background:#f5f5f5;
}

.header{
height:60px;
background:white;
border-bottom:1px solid #ddd;

display:flex;
align-items:center;

justify-content:flex-end;

padding-right:40px;
}

.launch-btn{

background:black;

color:white;

border:none;

padding:10px 18px;

cursor:pointer;
}

.overlay{

position:fixed;

top:0;

left:0;

right:0;

bottom:0;

display:none;

justify-content:center;

align-items:center;

background:rgba(0,0,0,.1);

}

.modal{

width:420px;

background:white;

padding:24px;

border-radius:10px;

box-shadow:
0 8px 24px rgba(0,0,0,.2);

}

.title{

font-size:22px;

margin-bottom:20px;

}

.field{

margin-bottom:18px;

}

label{

display:block;

margin-bottom:6px;

font-size:14px;

}

input,
select{

width:100%;

padding:10px;

box-sizing:border-box;

}

.footer{

display:flex;

justify-content:
space-between;

margin-top:24px;

}

.btn{

padding:10px 16px;

border:1px solid #ccc;

cursor:pointer;

background:white;

}

.primary{

background:black;

color:white;

}

.info{

display:none;

padding:12px;

background:#fff4cf;

margin-top:12px;

border-radius:6px;

font-size:13px;

}

</style>

</head>

<body>

<div class="header">

<button
class="launch-btn"
onclick="openModal()">

Launch workflow

</button>

</div>


<div class="overlay"
id="modal">

<div class="modal">

<div class="title">

NOS Management

</div>


<div class="field">

<label>

Device model

</label>

<select
id="model">

<option value="">

Select model

</option>

<option>

ACX5448

</option>

<option>

ACX7024

</option>

<option>

WHITEBOX_48X

</option>

</select>

</div>



<div class="field">

<label>

NOS version

</label>

<select
id="version">

<option>

Select version

</option>

</select>

</div>



<div class="field">

<label>

NOS image

</label>

<select
id="image">

<option>

Select image

</option>

</select>

</div>



<!-- NEW -->

<div class="field">

<label>

Installation Method

</label>

<select
id="method">

<option>

STANDARD

</option>

<option>

ONIE (Arrcus)

</option>

</select>

</div>



<div
id="onieBox"

class="info">

Whitebox flow

<br><br>

reboot
→ ONIE
→ install Arrcus
→ reload

</div>



<div class="field">

<label>

Delay before reload

</label>

<input
value="00:05">

</div>



<div class="field">

<label>

Device

</label>

<select>

<option>

leaf-01

</option>

<option>

leaf-02

</option>

<option>

spine-01

</option>

</select>

</div>



<div class="footer">

<button
class="btn"
onclick="clearForm()">

Clear

</button>


<div>

<button
class="btn"
onclick="closeModal()">

Cancel

</button>


<button
class="btn primary"

onclick="launch()">

Launch

</button>

</div>

</div>

</div>

</div>


<script>

const profile = {

ACX5448:{

versions:[
"20.2R1.10",
"21.1R3.11",
"24.2R1.18"
],

images:[
"acx-image.bin"
]

},

ACX7024:{

versions:[
"22.1R",
"24.1R"
],

images:[
"acx7024.bin"
]

},

WHITEBOX_48X:{

versions:[
"ArcOS-5.4",
"ArcOS-5.5"
],

images:[
"arcos-onie.bin"
]

}

};



function openModal(){

modal.style.display=
"flex";

}



function closeModal(){

modal.style.display=
"none";

}



model.onchange=
function(){

version.innerHTML="";

image.innerHTML="";

let p=
profile[
this.value
];

if(!p)
return;

p.versions.forEach(v=>{

version.innerHTML+=
`<option>${v}</option>`;

});

p.images.forEach(i=>{

image.innerHTML+=
`<option>${i}</option>`;

});

};



method.onchange=
function(){

onieBox.style.display=

this.value
.includes("ONIE")

?

"block"

:

"none";

};



function clearForm(){

document
.querySelectorAll(
"select,input"
)

.forEach(x=>{

if(
x.tagName==="INPUT"

)

x.value="";

else

x.selectedIndex=0;

});

onieBox.style.display=
"none";

}



function launch(){

let method=
document
.getElementById(
"method"
)

.value;


let msg=`

NOS Workflow Started


Model:
${model.value}


Version:
${version.value}


Image:
${image.value}


Method:
${method}

`;


if(
method
.includes(
"ONIE"
)

){

msg+=`

Trigger:
Whitebox Arrcus Install

`;

}

else{

msg+=`

Trigger:
Standard Install

`;

}


alert(msg);

closeModal();

}

</script>

</body>

</html>
