<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<title>SDNO Whitebox Inventory</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#fff;
color:#222;
}

.header{
height:64px;
border-bottom:1px solid #ddd;
display:flex;
align-items:center;
padding:0 24px;
}

.logo{
font-weight:700;
width:220px;
}

.nav{
display:flex;
gap:50px;
font-size:14px;
}

.right{
margin-left:auto;
display:flex;
gap:18px;
}

.sub{
height:48px;
display:flex;
align-items:center;
padding:0 24px;
border-bottom:1px solid #ececec;
gap:24px;
}

.tab{
cursor:pointer;
padding-bottom:8px;
}

.active{
border-bottom:2px solid black;
}

.page{
padding:18px 28px;
}

.hidden{
display:none;
}

.filters{
display:flex;
gap:10px;
margin-bottom:20px;
}

.filter{
padding:8px 14px;
background:#555;
color:white;
font-size:12px;
border-radius:2px;
}

.filter.active{
background:#1565c0;
}

.toolbar{
display:flex;
justify-content:flex-end;
gap:10px;
margin-bottom:16px;
}

.btn{
height:36px;
padding:0 18px;
background:black;
color:white;
border:none;
cursor:pointer;
}

.btn:disabled{
opacity:.35;
cursor:not-allowed;
}

.refresh{
width:36px;
background:white;
border:1px solid #ddd;
}

.title{
font-size:15px;
font-weight:600;
margin-bottom:16px;
}

table{
width:100%;
border-collapse:collapse;
}

th{
text-align:left;
padding:14px;
border-bottom:1px solid #ddd;
font-size:12px;
}

td{
padding:14px;
border-bottom:1px solid #eee;
font-size:13px;
}

.green{
color:#198754;
}

.red{
color:#d9534f;
}

.profile{
width:520px;
border:1px solid #ddd;
padding:20px;
margin-bottom:20px;
}

.row{
display:flex;
justify-content:space-between;
padding:14px 0;
border-bottom:1px solid #eee;
}

.footer{
position:fixed;
bottom:0;
left:0;
right:0;
height:28px;
background:#f5f5f5;
display:flex;
align-items:center;
padding:0 14px;
font-size:11px;
gap:20px;
}

.modal{
display:none;
position:fixed;
inset:0;
background:rgba(0,0,0,.45);
justify-content:center;
align-items:center;
}

.popup{
width:420px;
background:white;
padding:24px;
}

.popup input,
.popup select{
width:100%;
height:36px;
margin-top:6px;
margin-bottom:14px;
padding:0 8px;
}

.actions{
display:flex;
justify-content:flex-end;
gap:10px;
margin-top:20px;
}

</style>

</head>

<body>

<div class="header">

<div class="logo">
SAMSUNG Cognitiv/ SDNO
</div>

<div class="nav">

<div>Monitor</div>
<div>Fault</div>
<div>Inventory</div>
<div>Configuration</div>
<div>Security</div>
<div>System</div>
<div>Smart Suite</div>

</div>

<div class="right">
⚙ ☰ 👤
</div>

</div>


<div class="sub">

<div class="tab active"
onclick="showInventory()">
Whitebox Inventory
</div>

<div class="tab"
onclick="showProfile()">
OS Profile
</div>

</div>



<div
id="inventory"
class="page">

<div class="filters">

<div class="filter active">
ALL (4)
</div>

<div class="filter">
Ready for detect (1)
</div>

<div class="filter">
Waiting for NOS install (2)
</div>

<div class="filter">
Waiting for provision (1)
</div>

<div class="filter">
Provisioned (1)
</div>

</div>


<div class="toolbar">

<button
id="nosInstall"
class="btn">
NOS Install
</button>

<button
class="btn">
Provision
</button>

<button
class="refresh">
↻
</button>

</div>



<div class="title">
Whitebox Inventory
</div>


<table>

<tr>

<th></th>
<th>First discovered</th>
<th>Serial</th>
<th>Platform</th>
<th>Status</th>
<th>Note</th>

</tr>

<tr>

<td><input class="device" type="checkbox"></td>

<td>2026-06-11</td>

<td>WBX-001</td>

<td>WB-48X</td>

<td class="green">
Provisioned
</td>

<td>
ArcOS installed
</td>

</tr>


<tr>

<td><input class="device" type="checkbox"></td>

<td>2026-06-11</td>

<td>WBX-002</td>

<td>WB-48X</td>

<td class="red">
Progress Fail
</td>

<td>
Install failed
</td>

</tr>


<tr>

<td><input class="device" type="checkbox"></td>

<td>2026-06-10</td>

<td>WBX-003</td>

<td>WB-32Q</td>

<td class="red">
Progress Fail
</td>

<td>
DHCP timeout
</td>

</tr>

</table>

</div>




<div
id="profile"
class="page hidden">

<div class="profile">

<div class="row">
<div>Model</div>
<div>WB-48X</div>
</div>

<div class="row">
<div>NOS Version</div>
<div>ArcOS-5.4</div>
</div>

<div class="row">
<div>NOS Image</div>
<div>arcos-installer.bin</div>
</div>

<div class="row">
<div>Installation Type</div>
<div>ONIE</div>
</div>

</div>


<div class="profile">

<div class="row">
<div>Model</div>
<div>WB-32Q</div>
<div></div>
</div>

<div class="row">
<div>NOS Version</div>
<div>ArcOS-5.3</div>
</div>

<div class="row">
<div>NOS Image</div>
<div>arcos-32q.bin</div>
</div>

<div class="row">
<div>Installation Type</div>
<div>Standard</div>
</div>

</div>

</div>




<div
id="modal"
class="modal">

<div class="popup">

<h2>
NOS Management
</h2>

<br>

Device model

<select>
<option>WB-48X</option>
<option>WB-32Q</option>
</select>


NOS version

<select>
<option>ArcOS-5.4</option>
<option>ArcOS-5.3</option>
</select>


NOS image

<select>
<option>arcos-installer.bin</option>
<option>arcos-32q.bin</option>
</select>


Delay before reload

<input value="00:05">


<div class="actions">

<button
onclick="closeModal()">
Cancel
</button>

<button>
Launch
</button>

</div>

</div>

</div>




<div class="footer">

Connected

MINOR

SAO-0004

ALARM

[SDNO]

</div>




<script>

function showProfile(){

inventory.classList.add(
"hidden"
);

profile.classList.remove(
"hidden"
);

}

function showInventory(){

profile.classList.add(
"hidden"
);

inventory.classList.remove(
"hidden"
);

}


let checks=
document.querySelectorAll(
".device"
);

let btn=
document.getElementById(
"nosInstall"
);

function update(){

let selected=
document.querySelectorAll(
".device:checked"
).length;

btn.disabled=
selected>0;

}

checks.forEach(

x=>x.addEventListener(
"change",
update

)

);

update();


btn.onclick=()=>{

if(btn.disabled)
return;

modal.style.display=
"flex";

};


function closeModal(){

modal.style.display=
"none";

}

modal.onclick=(e)=>{

if(
e.target===modal
)

closeModal();

};

</script>

</body>

</html>
